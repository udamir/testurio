{
  "name": "@testurio/adapter-clickhouse",
  "version": "0.6.5",
  "description": "ClickHouse adapter for Testurio DataSource",
  "keywords": [
    "testurio",
    "clickhouse",
    "adapter",
    "testing",
    "e2e"
  ],
  "author": "Damir Yusipov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/udamir/testurio.git",
    "directory": "packages/adapter-clickhouse"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --clean",
    "test": "vitest run",
    "lint": "biome check src",
    "prepublish": "V=$(node -p \"require('../../package.json').version\") && npm pkg set version=$V peerDependencies.testurio=^$V && pnpm run lint && pnpm run build"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.0"
  },
  "peerDependencies": {
    "testurio": "^0.6.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "testurio": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}

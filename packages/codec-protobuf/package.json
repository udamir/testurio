{
  "name": "@testurio/codec-protobuf",
  "version": "0.7.3",
  "description": "Protobuf codec for testurio Publisher/Subscriber — per-topic message-type dispatch via the codec dispatch key.",
  "keywords": [
    "testurio",
    "protobuf",
    "codec",
    "mq",
    "testing"
  ],
  "author": "Damir Yusipov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/udamir/testurio.git",
    "directory": "packages/codec-protobuf"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --clean",
    "test": "vitest run",
    "lint": "biome check src",
    "prepublish": "V=$(node -p \"require('../../package.json').version\") && npm pkg set version=$V peerDependencies.testurio=^$V && pnpm run lint && pnpm run build"
  },
  "dependencies": {
    "protobufjs": "^8.0.0"
  },
  "peerDependencies": {
    "testurio": "^0.7.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "testurio": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
